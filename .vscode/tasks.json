{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build tracker",
            "type": "shell",
            "command": "gcc",
            "args": [
                "SRC\\main.c",
                "SRC\\tarefa.c",
                "SRC\\arquivo.c",
